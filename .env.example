# Optional demo values mapped into <LlamaSwapWidget apiKeys={...}>.
# In production, pass these directly from your app config/backend response.
VITE_LLAMASWAP_DEFILLAMA_API_KEY=
VITE_LLAMASWAP_ZEROX_API_KEY=
VITE_LLAMASWAP_ONEINCH_API_KEY=
VITE_LLAMASWAP_HASHFLOW_API_KEY=

# Required only for `npm run dev`, which uses Privy embedded wallets.
VITE_PRIVY_APP_ID=
VITE_PRIVY_CLIENT_ID=
# Optional for testing external wallets in the Privy modal.
VITE_WALLETCONNECT_PROJECT_ID=

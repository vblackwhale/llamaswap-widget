# Optional: enables adapters that call DefiLlama's proxy API.
# Leave empty when using only direct public adapters such as Odos.
VITE_LLAMASWAP_DEFILLAMA_API_KEY=

# Optional: use your own backend proxy instead of swap-api.defillama.com.
# The proxy should accept the same query/body shape as /dexAggregatorQuote.
VITE_LLAMASWAP_PROXY_URL=

# Optional third-party keys for a future backend proxy.
OX_API_KEY=
INCH_API_KEY=
HASHFLOW_API_KEY=

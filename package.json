{
	"name": "llamaswap-widget",
	"version": "1.1.0",
	"description": "React LlamaSwap widget for embedded wallet swap flows without iframes for Privy compatibility",
	"private": false,
	"keywords": [
		"llamaswap",
		"defillama",
		"swap",
		"dex",
		"aggregator",
		"widget",
		"react",
		"wagmi",
		"viem",
		"privy",
		"embedded-wallet"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/LedgityYield/llamaswap-widget.git"
	},
	"bugs": {
		"url": "https://github.com/LedgityYield/llamaswap-widget/issues"
	},
	"homepage": "https://github.com/LedgityYield/llamaswap-widget#readme",
	"sideEffects": [
		"src/styles.css"
	],
	"license": "GPL-3.0-or-later",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./styles.css": "./src/styles.css"
	},
	"files": [
		"dist",
		"src/styles.css",
		"README.md",
		"NOTICE"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"dev": "vite --config demo/vite.config.ts",
		"dev:types": "tsc -p tsconfig.json --watch --preserveWatchOutput",
		"prepack": "npm run build",
		"prepublishOnly": "node scripts/bump-minor-on-new-commit.mjs && npm run build",
		"prepare": "npm run build",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"version:minor-on-new-commit": "node scripts/bump-minor-on-new-commit.mjs"
	},
	"peerDependencies": {
		"@tanstack/react-query": "^5.0.0",
		"react": "^18.2.0 || ^19.0.0",
		"react-dom": "^18.2.0 || ^19.0.0",
		"viem": "^2.0.0",
		"wagmi": "^2.0.0"
	},
	"dependencies": {
		"@chakra-ui/icons": "^2.0.12",
		"@chakra-ui/react": "^2.2.1",
		"@emotion/react": "^11.0.0",
		"@emotion/styled": "^11.0.0",
		"@tanstack/react-virtual": "^3.0.0",
		"bignumber.js": "^9.0.2",
		"ethers": "^5.7.1",
		"framer-motion": "^6.0.0",
		"lodash": "^4.17.21",
		"react-feather": "^2.0.10",
		"react-select": "^5.3.2",
		"styled-components": "^5.3.5"
	},
	"devDependencies": {
		"@privy-io/react-auth": "3.13.1",
		"@privy-io/wagmi": "4.0.1",
		"@rollup/plugin-inject": "^5.0.5",
		"@tanstack/react-query": "^5.0.0",
		"@types/react": "^18.2.0",
		"@types/styled-components": "^5.1.25",
		"@vitejs/plugin-react": "^5.0.0",
		"buffer": "^6.0.3",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"react-is": "^18.2.0",
		"typescript": "^5.0.0",
		"viem": "^2.0.0",
		"vite": "^6.0.0",
		"wagmi": "^2.0.0"
	},
	"x-version-commit": "fd3b7989207012ccfbb8f8ae7e77466eb8cc415c"
}
